# ============================================================
# VulnKB 环境变量配置文件
# 使用方式：复制此文件为 .env 并填入实际值
#   cp .env.example .env
# ============================================================

# ---------- 管理员账号（首次启动时写入数据库） ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Chang3Me!@2026

# ---------- JWT 签名密钥（务必替换为随机长字符串） ----------
# 可用命令生成：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-random-64-char-hex-string

# ---------- JWT 令牌过期时间（分钟） ----------
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---------- 服务监听地址 ----------
# APP_PORT: VulnKB 内部端口（一般无需修改）
APP_PORT=8000

# ---------- HTTPS 公网部署（Nginx 反向代理） ----------
# HTTPS_PORT: 对外暴露的 HTTPS 端口
HTTPS_PORT=6868
